# ── VLM Provider Selection ───────────────────────────────────────────────────
# "azure"  → Azure OpenAI (GPT-4o with Vision) — 권장
# "gemini" → Google Gemini Vision (기존 방식)
VLM_PROVIDER=azure

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# Azure Portal > Azure OpenAI 리소스 > 키 및 엔드포인트 에서 확인
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# Azure OpenAI Studio > 배포 탭에서 배포한 모델의 Deployment 이름
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API 버전 (변경 불필요)
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Google Gemini (VLM_PROVIDER=gemini 선택 시 사용) ─────────────────────────
# GEMINI_API_KEY=your-gemini-api-key-here
